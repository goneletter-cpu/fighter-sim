<?xml version="1.0"?>
<fdm_config name="minimal" version="2.0">

  <!-- 基本几何参数 -->
  <metrics>
    <wingarea unit="FT2">150.0</wingarea>
    <wingspan unit="FT">35.0</wingspan>
    <chord unit="FT">4.3</chord>
    <htailarea unit="FT2">20.0</htailarea>
    <htailarm unit="FT">12.0</htailarm>
    <vtailarea unit="FT2">10.0</vtailarea>
    <vtailarm unit="FT">10.0</vtailarm>
    <location name="CG" unit="FT">
      <x>0.0</x>
      <y>0.0</y>
      <z>0.0</z>
    </location>
  </metrics>

  <!-- 质量与惯量 -->
  <mass_balance>
    <emptywt unit="LBS">1200.0</emptywt>
    <location name="CG" unit="FT">
      <x>0.0</x>
      <y>0.0</y>
      <z>0.0</z>
    </location>
    <ixx unit="SLUG*FT2">900.0</ixx>
    <iyy unit="SLUG*FT2">1200.0</iyy>
    <izz unit="SLUG*FT2">1800.0</izz>
    <ixz unit="SLUG*FT2">0.0</ixz>
  </mass_balance>

  <!-- 起落架（简单接触点） -->
  <ground_reactions>
    <contact type="BOGEY" name="NOSE">
      <location unit="FT">
        <x>2.0</x>
        <y>0.0</y>
        <z>-2.5</z>
      </location>
      <static_friction>0.8</static_friction>
      <dynamic_friction>0.5</dynamic_friction>
      <spring_coeff unit="LBS/FT">3000.0</spring_coeff>
      <damping_coeff unit="LBS/FT/SEC">500.0</damping_coeff>
    </contact>
    <contact type="BOGEY" name="LEFT">
      <location unit="FT">
        <x>-1.0</x>
        <y>-5.0</y>
        <z>-2.5</z>
      </location>
      <static_friction>0.8</static_friction>
      <dynamic_friction>0.5</dynamic_friction>
      <spring_coeff unit="LBS/FT">3000.0</spring_coeff>
      <damping_coeff unit="LBS/FT/SEC">500.0</damping_coeff>
    </contact>
    <contact type="BOGEY" name="RIGHT">
      <location unit="FT">
        <x>-1.0</x>
        <y>5.0</y>
        <z>-2.5</z>
      </location>
      <static_friction>0.8</static_friction>
      <dynamic_friction>0.5</dynamic_friction>
      <spring_coeff unit="LBS/FT">3000.0</spring_coeff>
      <damping_coeff unit="LBS/FT/SEC">500.0</damping_coeff>
    </contact>
  </ground_reactions>

  <!-- 推进系统（修正后的发动机） -->
  <propulsion>
    <engine name="simple_thrust" type="direct">
      <thruster>
        <location unit="FT">
          <x>5.0</x>
          <y>0.0</y>
          <z>0.0</z>
        </location>
      </thruster>
      <function name="thrust">
        <product>
          <property>fcs/throttle-cmd-norm</property>
          <value>2000.0</value>
        </product>
      </function>
    </engine>
  </propulsion>

  <!-- 气动系数（极简版本） -->
  <aerodynamics>
    <axis name="LIFT">
      <function name="aero/force/Lift">
        <description>Lift = qbar * Sw * CL</description>
        <product>
          <property>aero/qbar-psf</property>
          <property>metrics/wingarea</property>
          <value>0.5</value>  <!-- CL=0.5 简单假设 -->
        </product>
      </function>
    </axis>
    <axis name="DRAG">
      <function name="aero/force/Drag">
        <product>
          <property>aero/qbar-psf</property>
          <property>metrics/wingarea</property>
          <value>0.03</value> <!-- CD=0.03 -->
        </product>
      </function>
    </axis>
    <axis name="PITCH">
      <function name="aero/moment/Pitch">
        <product>
          <property>fcs/elevator-cmd-norm</property>
          <value>500.0</value>
        </product>
      </function>
    </axis>
    <axis name="ROLL">
      <function name="aero/moment/Roll">
        <product>
          <property>fcs/aileron-cmd-norm</property>
          <value>300.0</value>
        </product>
      </function>
    </axis>
    <axis name="YAW">
      <function name="aero/moment/Yaw">
        <product>
          <property>fcs/rudder-cmd-norm</property>
          <value>200.0</value>
        </product>
      </function>
    </axis>
  </aerodynamics>

  <!-- 飞行控制系统（简单传递油门/舵面指令） -->
  <flight_control name="FCS">
    <channel name="Pitch">
      <summer name="Pitch Trim">
        <input>fcs/throttle-cmd-norm</input>
        <clipto>
          <min>-1</min>
          <max>1</max>
        </clipto>
      </summer>
    </channel>
  </flight_control>

</fdm_config>