<?xml version="1.0"?>
<!--
  c172p.xml — stripped for standalone JSBSim use.

  Kept:   aerodynamics, mass/inertia, landing gear, FCS surface mapping,
          flap schedule, propulsion (engine + prop).
  Removed: all <system> file references, external_reactions (hydro/tiedown),
           ice/damage/bushkit pointmasses, float-chamber tank.

  Engine is always running: tank[0] has unlimited fuel (999999 lbs),
  no fuel-burn concern, no kill/cutoff logic anywhere in this file.
  jsbsim_adapter calls set-running=1 on init; engine runs freely after that.
-->
<fdm_config name="c172" version="2.0" release="BETA"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://jsbsim.sourceforge.net/JSBSim.xsd">

    <fileheader>
        <description>Cessna 172P — stripped standalone (no system files)</description>
    </fileheader>

    <!-- ── Geometry ──────────────────────────────────────────────────────── -->
    <metrics>
        <wingarea  unit="FT2"> 174   </wingarea>
        <wingspan  unit="FT">   35.8 </wingspan>
        <chord     unit="FT">    4.9 </chord>
        <htailarea unit="FT2">  21.9 </htailarea>
        <htailarm  unit="FT">   15.7 </htailarm>
        <vtailarea unit="FT2">  16.5 </vtailarea>
        <vtailarm  unit="FT">    0   </vtailarm>
        <location name="AERORP" unit="IN">
            <x> 41.2 </x> <y> 0 </y> <z> 29.3 </z>
        </location>
        <location name="EYEPOINT" unit="IN">
            <x> 37 </x> <y> 0 </y> <z> 48 </z>
        </location>
        <location name="VRP" unit="IN">
            <x> 34 </x> <y> 0 </y> <z> 35.75 </z>
        </location>
    </metrics>

    <!-- ── Mass & inertia ────────────────────────────────────────────────── -->
    <mass_balance>
        <ixx unit="SLUG*FT2">  948 </ixx>
        <iyy unit="SLUG*FT2"> 1285 </iyy>
        <izz unit="SLUG*FT2"> 1906 </izz>
        <ixy unit="SLUG*FT2">    0 </ixy>
        <ixz unit="SLUG*FT2">    0 </ixz>
        <iyz unit="SLUG*FT2">    0 </iyz>
        <emptywt unit="LBS"> 1467 </emptywt>
        <location name="CG" unit="IN">
            <x> 39.06 </x> <y> 0 </y> <z> 25 </z>
        </location>
        <pointmass name="Pilot">
            <weight unit="LBS"> 180 </weight>
            <location name="POINTMASS" unit="IN">
                <x> 36 </x> <y> -14 </y> <z> 24 </z>
            </location>
        </pointmass>
    </mass_balance>

    <!-- ── Landing gear ──────────────────────────────────────────────────── -->
    <ground_reactions>
        <contact type="BOGEY" name="NOSE">
            <location unit="IN">
                <x> -7.3 </x> <y> 0 </y> <z> -20.3 </z>
            </location>
            <static_friction>  0.8  </static_friction>
            <dynamic_friction> 0.5  </dynamic_friction>
            <rolling_friction> 0.02 </rolling_friction>
            <spring_coeff  unit="LBS/FT">     3600 </spring_coeff>
            <damping_coeff unit="LBS/FT/SEC"> 1200 </damping_coeff>
            <max_steer unit="DEG"> 30 </max_steer>
            <brake_group> NONE </brake_group>
            <retractable>0</retractable>
        </contact>
        <contact type="BOGEY" name="LEFT_MAIN">
            <location unit="IN">
                <x> 57.3 </x> <y> -43 </y> <z> -15.3 </z>
            </location>
            <static_friction>  0.8  </static_friction>
            <dynamic_friction> 0.5  </dynamic_friction>
            <rolling_friction> 0.02 </rolling_friction>
            <spring_coeff  unit="LBS/FT">     5400 </spring_coeff>
            <damping_coeff unit="LBS/FT/SEC"> 1800 </damping_coeff>
            <max_steer unit="DEG"> 0 </max_steer>
            <brake_group> LEFT </brake_group>
            <retractable>0</retractable>
        </contact>
        <contact type="BOGEY" name="RIGHT_MAIN">
            <location unit="IN">
                <x> 57.3 </x> <y> 43 </y> <z> -15.1 </z>
            </location>
            <static_friction>  0.8  </static_friction>
            <dynamic_friction> 0.5  </dynamic_friction>
            <rolling_friction> 0.02 </rolling_friction>
            <spring_coeff  unit="LBS/FT">     5400 </spring_coeff>
            <damping_coeff unit="LBS/FT/SEC"> 1800 </damping_coeff>
            <max_steer unit="DEG"> 0 </max_steer>
            <brake_group> RIGHT </brake_group>
            <retractable>0</retractable>
        </contact>
    </ground_reactions>

    <!-- ── Propulsion ────────────────────────────────────────────────────── -->
    <!--
      Single tank [0] with unlimited fuel (999999 lbs ≈ never empty).
      Engine feeds directly from tank[0] — no float chamber, no fuel transfer.
      No system files → no kill/cutoff logic. Engine starts via set-running=1
      in jsbsim_adapter and stays running for the entire simulation.
    -->
    <propulsion>
        <engine file="eng_io320">
            <feed>0</feed>
            <thruster file="prop_75in2f">
                <location unit="IN">
                    <x> -37.7 </x> <y> 0 </y> <z> 29.3 </z>
                </location>
                <orient unit="DEG">
                    <roll> 0 </roll> <pitch> 0 </pitch> <yaw> 0 </yaw>
                </orient>
                <sense>    1 </sense>
                <p_factor> 15 </p_factor>
            </thruster>
        </engine>

        <tank type="FUEL">
            <location unit="IN">
                <x> 48 </x> <y> 0 </y> <z> 55 </z>
            </location>
            <capacity unit="LBS"> 999999 </capacity>
            <contents unit="LBS"> 999999 </contents>
            <type>AVGAS</type>
        </tank>
    </propulsion>

    <!-- ── Flight control surface mapping ───────────────────────────────── -->
    <flight_control name="FCS: c172p-standalone">

        <channel name="Pitch">
            <aerosurface_scale name="Elevator Control">
                <input>fcs/elevator-cmd-norm</input>
                <gain>0.01745</gain>
                <range> <min>-28</min> <max>23</max> </range>
                <o>fcs/elevator-pos-rad</o>
            </aerosurface_scale>
        </channel>

        <channel name="Roll">
            <aerosurface_scale name="Left Aileron Control">
                <input>fcs/aileron-cmd-norm</input>
                <gain>0.01745</gain>
                <range> <min>-20</min> <max>15</max> </range>
                <o>fcs/left-aileron-pos-rad</o>
            </aerosurface_scale>
            <aerosurface_scale name="Right Aileron Control">
                <input>fcs/aileron-cmd-norm</input>
                <gain>-0.01745</gain>
                <range> <min>-20</min> <max>15</max> </range>
                <o>fcs/right-aileron-pos-rad</o>
            </aerosurface_scale>
        </channel>

        <channel name="Yaw">
            <aerosurface_scale name="Rudder Control">
                <input>fcs/rudder-cmd-norm</input>
                <gain>0.01745</gain>
                <range> <min>-16</min> <max>16</max> </range>
                <o>fcs/rudder-pos-rad</o>
            </aerosurface_scale>
        </channel>

        <channel name="Flaps">
            <kinematic name="Flap Control">
                <input>fcs/flap-cmd-norm</input>
                <traverse>
                    <setting> <position>  0</position> <time>0</time> </setting>
                    <setting> <position> 10</position> <time>2</time> </setting>
                    <setting> <position> 20</position> <time>2</time> </setting>
                    <setting> <position> 30</position> <time>2</time> </setting>
                </traverse>
                <o>fcs/flap-pos-deg</o>
            </kinematic>
        </channel>

    </flight_control>

    <!-- ── Aerodynamics ──────────────────────────────────────────────────── -->
    <aerodynamics>

        <alphalimits unit="RAD">
            <min>-0.087</min>
            <max>0.28</max>
        </alphalimits>
        <hysteresis_limits unit="RAD">
            <min>0.15</min>
            <max>0.297</max>
        </hysteresis_limits>

        <function name="aero/function/kCDge">
            <description>Drag reduction in ground effect</description>
            <table>
                <independentVar>aero/h_b-mac-ft</independentVar>
                <tableData>
                    0.0  0.480   0.1  0.515   0.15 0.629   0.2  0.709
                    0.3  0.815   0.4  0.882   0.5  0.928   0.6  0.962
                    0.7  0.988   0.8  1.000   1.0  1.000
                </tableData>
            </table>
        </function>

        <function name="aero/function/kCLge">
            <description>Lift increase in ground effect</description>
            <table>
                <independentVar>aero/h_b-mac-ft</independentVar>
                <tableData>
                    0.0  1.203   0.1  1.127   0.15 1.090   0.2  1.073
                    0.3  1.046   0.4  1.028   0.5  1.019   0.6  1.013
                    0.7  1.008   0.8  1.006   0.9  1.003   1.0  1.002
                    1.1  1.000
                </tableData>
            </table>
        </function>

        <function name="aero/function/vel-propwash-fps">
            <sum>
                <property>propulsion/engine/prop-induced-velocity_fps</property>
            </sum>
        </function>
        <function name="aero/function/qbar-propwash-psf">
            <product>
                <property>aero/function/vel-propwash-fps</property>
                <property>aero/function/vel-propwash-fps</property>
                <property>atmosphere/rho-slugs_ft3</property>
                <value>0.5</value>
            </product>
        </function>
        <function name="aero/function/velocity-induced-fps">
            <sum>
                <property>velocities/u-aero-fps</property>
                <property>propulsion/engine/prop-induced-velocity_fps</property>
            </sum>
        </function>
        <function name="aero/function/qbar-induced-psf">
            <product>
                <property>aero/function/velocity-induced-fps</property>
                <property>aero/function/velocity-induced-fps</property>
                <property>atmosphere/rho-slugs_ft3</property>
                <value>0.5</value>
            </product>
        </function>
        <function name="fcs/aileron-pos-rad-avgd">
            <avg>
                <property>fcs/left-aileron-pos-rad</property>
                <product>
                    <property>fcs/right-aileron-pos-rad</property>
                    <value>-1</value>
                </product>
            </avg>
        </function>

